{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "description": "Recursive self-improving coding agent in ClojureScript",
  "scripts": {
    "supervisor": "shadow-cljs compile supervisor && node out/supervisor.js",
    "agent": "shadow-cljs compile agent && node out/agent.js",
    "lab-worker": "shadow-cljs release lab-worker",
    "test": "shadow-cljs compile test",
    "watch:supervisor": "shadow-cljs watch supervisor",
    "watch:agent": "shadow-cljs watch agent",
    "watch:test": "shadow-cljs watch test"
  },
  "dependencies": {
    "shadow-cljs": "^2.28.0"
  }
}
